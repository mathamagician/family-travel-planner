# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit the real file

# ── Anthropic (AI activity generation) ─────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Supabase (database + auth) ─────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key — NEVER expose to browser, server-only
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Internal API secret (server-to-server calls) ───────────
# Generate with: openssl rand -hex 32  (or any long random string)
INTERNAL_API_SECRET=your-random-secret-here

# ── Affiliate tags ──────────────────────────────────────────
# Amazon Associates: sign up at affiliate-program.amazon.com
# Your tracking ID looks like: yourname-20
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=familytravel0a-20

# Viator affiliate: sign up at partnerresources.viator.com
# Links: viator.com/searchResults/all?text=ACTIVITY&pid=PID&mcid=42383&medium=link
# Leave blank to still show Viator buttons (just without commission)
NEXT_PUBLIC_VIATOR_PID=P00291411

# BabyQuip affiliate: rent cribs, strollers, car seats at destination
# Sign up at babyquip.com — your affiliate link includes ?a=YOUR_ID
NEXT_PUBLIC_BABYQUIP_URL=https://www.babyquip.com?a=b33db96

# ── Google Analytics (GA4) ──────────────────────────────────
# Found in: Google Analytics → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
